# DynamicMPNN Environment Configuration
# Copy to `.env` and update paths for your machine.

# =============================================================================
# Core Project Paths
# =============================================================================

# Project root directory (where this repo is cloned)
PROJECT_PATH=/path/to/DynamicMPNN

# Public databases directory (PDB mirror, processed data, etc.)
PUBLIC_DB=/path/to/public_databases

# Clustering data directory (mmseqs2 outputs, cluster CSVs)
CLUSTERING_BASE=/path/to/clustering

# =============================================================================
# Training Data Paths (downloadable from Zenodo)
# =============================================================================
# These directories contain the final .pt files for training/evaluation.
# Download from Zenodo and extract to PUBLIC_DB:
#   - train_pt_multi_chain/   (multi-chain training)
#   - train_pt_single_chain/  (single-chain training)
#   - val_pt_multi_chain/     (multi-chain validation)
#   - val_pt_single_chain/    (single-chain validation)
#   - test_pt_multi_chain/    (multi-chain test)
#   - test_pt_single_chain/   (single-chain test)

# Multi-chain mode
PROCESSED_DIR=${PUBLIC_DB}/train_pt_multi_chain
VAL_PROCESSED_DIR=${PUBLIC_DB}/val_pt_multi_chain
TEST_PROCESSED_DIR=${PUBLIC_DB}/test_pt_multi_chain

# Single-chain mode
PROCESSED_DIR_SINGLE=${PUBLIC_DB}/train_pt_single_chain
VAL_PROCESSED_DIR_SINGLE=${PUBLIC_DB}/val_pt_single_chain
TEST_PROCESSED_DIR_SINGLE=${PUBLIC_DB}/test_pt_single_chain

# Raw downloads cache
DOWNLOAD_DIR=${PUBLIC_DB}/pdb_cache

# Foldseek alignment outputs
FOLDSEEK_DIR=${PUBLIC_DB}/foldseek_alignments

# =============================================================================
# Hydra/Training Paths
# =============================================================================

# Where training runs/checkpoints are saved
RUNS_PATH=${PROJECT_PATH}/runs
ROOT_DIR=${PROJECT_PATH}
DATA_PATH=${PUBLIC_DB}

# =============================================================================
# Weights & Biases (optional)
# =============================================================================

WANDB_ENTITY=your_entity
WANDB_PROJECT=dynamicmpnn

# =============================================================================
# AlphaFold3 Evaluation (optional)
# =============================================================================

AF3_EXECUTABLE=/path/to/python
AF3_SCRIPT=/path/to/run_alphafold.py
AF3_MODEL_DIR=/path/to/models
AF3_DB_DIR=/path/to/public_databases
AF3_ENV_SCRIPT=/path/to/af3_env.sh
